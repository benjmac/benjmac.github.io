{
  "compilerOptions": {
    "target": "ES6",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "skipLibCheck": true,
    "baseUrl": "."
  },
  "include": ["client/**/*", "shared/**/*", "types/**/*"],
  "exclude": ["node_modules", "public"]
}
