{
  "name": "benjmac.github.io",
  "version": "1.0.0",
  "description": "Ben's personal site",
  "engines": {
    "node": ">=14"
  },
  "main": "index.js",
  "scripts": {
    "clean": "rm -f public/bundle.js public/bundle.js.LICENSE.txt public/style.css",
    "build-client": "npm run clean && webpack",
    "build-client-watch": "NODE_ENV='development' webpack -w",
    "start": "serve public",
    "predeploy": "npm run build-client",
    "deploy": "gh-pages -d public",
    "lint": "eslint ./ --ignore-path .gitignore",
    "lint-fix": "npm run lint -- --fix",
    "prettify": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "npm run lint-fix"
    ],
    "*.{css,scss,json,md}": [
      "prettier --write"
    ]
  },
  "author": "benjmac",
  "homepage": "https://benjmac.github.io",
  "dependencies": {
    "react": "^16.8.6",
    "react-dom": "^16.8.6",
    "react-router-dom": "^5.3.4",
    "react-sizeme": "^3.0.1",
    "semantic-ui-css": "2.4.1",
    "semantic-ui-react": "2.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.4.3",
    "@babel/polyfill": "^7.4.3",
    "@babel/preset-env": "^7.4.3",
    "@types/react": "^16.14.69",
    "@types/react-dom": "^16.9.25",
    "@types/react-router-dom": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "css-loader": "^7.1.4",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.4",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "prettier": "^3.5.0",
    "sass": "^1.97.3",
    "sass-loader": "^16.0.7",
    "serve": "^14.2.5",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.105.2",
    "webpack-cli": "^5.1.4"
  }
}
